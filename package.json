{
  "name": "noorg",
  "version": "2.0.0",
  "private": true,
  "description": "Typed, durable multi-agent coordination runtime",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.test.json --noEmit",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "test:integration": "jest --runInBand tests/integration",
    "test:live": "NOORG_LLM_PROVIDER=openai jest --runInBand tests/live",
    "lint": "eslint src tests scripts --ext .ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "quality": "npm run type-check && npm run lint && npm run format:check",
    "validate:text": "tsx scripts/validate-repository.ts",
    "validate:docs": "tsx scripts/validate-docs.ts",
    "validate:units": "tsx scripts/validate-units.ts",
    "units:manifest:check": "tsx scripts/units-manifest.ts check",
    "units:manifest:diff": "tsx scripts/units-manifest.ts diff",
    "units:manifest:update": "tsx scripts/units-manifest.ts write",
    "validate:contracts": "tsx scripts/validate-contracts.ts",
    "validate:decisions": "tsx scripts/validate-decisions.ts",
    "api:openapi": "tsx scripts/generate-openapi.ts",
    "api:openapi:check": "tsx scripts/generate-openapi.ts check",
    "manuscript:evidence": "tsx scripts/manuscript.ts evidence",
    "manuscript:figures": "tsx scripts/manuscript.ts figures",
    "manuscript:hydrate": "tsx scripts/manuscript.ts hydrate",
    "manuscript:validate": "tsx scripts/manuscript.ts validate",
    "manuscript:render": "tsx scripts/manuscript.ts render",
    "manuscript:check": "tsx scripts/manuscript.ts check",
    "validate": "npm run quality && npm test && npm run validate:text && npm run validate:docs && npm run validate:units && npm run units:manifest:check && npm run api:openapi:check && npm run validate:contracts && npm run validate:decisions && npm run build",
    "release:check": "npm run validate && npm run example && npm audit --audit-level=high && npm run manuscript:check && git diff --check",
    "clean": "tsx scripts/clean-generated.ts",
    "example": "tsx examples/basic-workflow.ts"
  },
  "dependencies": {
    "openai": "^4.104.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
