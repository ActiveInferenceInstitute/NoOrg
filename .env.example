NODE_ENV=development
NOORG_LLM_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_MS=250
OPENAI_PROMPT_COST_PER_MILLION_USD=0
OPENAI_COMPLETION_COST_PER_MILLION_USD=0
NOORG_HOST=127.0.0.1
NOORG_PORT=3000
NOORG_HTTP_AUTH_TOKEN=
NOORG_HTTP_MAX_BODY_BYTES=1048576
NOORG_STATE_PATH=data/state.json
NOORG_POLL_INTERVAL_MS=100
NOORG_MAX_CONCURRENT_TASKS=4
NOORG_TASK_TIMEOUT_MS=60000
NOORG_SHUTDOWN_TIMEOUT_MS=10000
NOORG_MAX_TASK_INPUT_BYTES=1048576
NOORG_MAX_RESULT_BYTES=1048576
NOORG_MAX_WORKFLOW_DEPTH=32
NOORG_MAX_WORKFLOW_CHILDREN=100
NOORG_PROVIDER_BUDGET_USD=
NOORG_PROVIDER_MAX_REQUESTS_PER_MINUTE=0
NOORG_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=5
NOORG_PROVIDER_CIRCUIT_COOLDOWN_MS=30000
NOORG_AGENT_MODULES=
# For modules outside the checkout: absolute-or-relative-path=sha256-digest entries.
NOORG_AGENT_MODULE_TRUSTED_SHA256=
NOORG_METRICS_ENABLED=true
